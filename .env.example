# =========================================================
# Environment Variables Example File
# Copy this file as .env and fill actual values
# =========================================================

# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Atlas Connection
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/lostfound_db

# JWT / Authentication Secret
JWT_SECRET=your_super_secret_jwt_key_here

# Session Secret (if using express-session)
SESSION_SECRET=your_session_secret_here

# File Upload Configuration
UPLOAD_PATH=server/uploads
MAX_FILE_SIZE=5242880

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Email Service (optional for OTP / notifications)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password

# Admin Access (optional)
ADMIN_EMAIL=admin@college.edu
ADMIN_PASSWORD=admin123
